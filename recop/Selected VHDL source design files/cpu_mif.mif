WIDTH=16;
DEPTH=16;

ADDRESS_RADIX=HEX;
DATA_RADIX=HEX;

CONTENT BEGIN
    0000 : 1001;   -- LOAD
    0001 : 2002;   -- ADD
    0002 : 3003;   -- STORE
    0003 : FFFF;   -- HALT

    0004 : 0000;
    0005 : 0000;
    0006 : 0000;
    0007 : 0000;
    0008 : 0000;
    0009 : 0000;
    000A : 0000;
    000B : 0000;
    000C : 0000;
    000D : 0000;
    000E : 0000;
    000F : 0000;
END;
