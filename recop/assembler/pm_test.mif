-- ============================================================================
-- pm_test.mif  –  ReCOP PM simulation test content  (v2: [AM:2][OP:6])
--
-- First 32 locations = all 31 ISA forms from example2.asm (one per form)
-- plus the trailing NOOP at address 31 (label "target").
-- Locations 32-511 = NOOP (0x34000000).
--
-- Encoding format: [AM:2][OP:6][Rz:4][Rx:4][OPERAND:16]
-- Matches classmates' opcodes.vhd and control_signal_generator.vhd.
--
-- Usage:  copy this file to program.mif before running PM simulation.
--         cp pm_test.mif program.mif
-- ============================================================================

DEPTH = 512;
WIDTH = 32;
ADDRESS_RADIX = HEX;
DATA_RADIX = HEX;

CONTENT
BEGIN

-- addr : encoding        ; instruction
000 : 481200FF;            -- AND  R1  R2  #0x00FF
001 : C8120000;            -- AND  R1  R1  R2
002 : 4C32000F;            -- OR   R3  R2  #0x0F
003 : CC340000;            -- OR   R3  R3  R4
004 : 7856000A;            -- ADD  R5  R6  #10
005 : F8560000;            -- ADD  R5  R5  R6
006 : 43780001;            -- SUBV R7  R8  #1
007 : 44900005;            -- SUB  R9  #5
008 : 40A01234;            -- LDR  R10 #0x1234
009 : C0BC0000;            -- LDR  R11 R12
00A : 80D00014;            -- LDR  R13 $20
00B : 42E0002A;            -- STR  R14 #42
00C : C2F10000;            -- STR  R15 R1
00D : 8202001E;            -- STR  R2  $30
00E : 5800001F;            -- JMP  target
00F : D8030000;            -- JMP  R3
010 : 5C40001F;            -- PRESENT R4  target
011 : E8050000;            -- DATACALL R5
012 : 69060077;            -- DATACALL R6  #0x77
013 : 5400001F;            -- SZ   target
014 : 10000000;            -- CLFZ
015 : B7700000;            -- LSIP R7
016 : BA080000;            -- SSOP R8
017 : 34000000;            -- NOOP
018 : 9D000032;            -- STRPC $50
019 : 3C000000;            -- CER
01A : 3E000000;            -- CEOT
01B : 3F000000;            -- SEOT
01C : B6900000;            -- LER  R9
01D : BB0A0000;            -- SSVOP R10
01E : 5EB0FFFF;            -- MAX  R11 #0xFFFF
01F : 34000000;            -- NOOP  (target, PC 31 = 0x1F)

[020..1FF] : 34000000;     -- NOOP  (unused locations)

END;
