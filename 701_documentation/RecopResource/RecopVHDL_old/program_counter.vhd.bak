library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

use work.recop_types.all;
use work.various_constants.all;

entity program_counter is
    port(
        clk : in bit_1;
        init : in bit_1;
        reset : in bit_1;

        pc_plus_1 : in bit_16;
        current_pc:    out bit_16
    );
end program_counter;
architecture beh of program_counter is
    signal next_pc : bit_16;
    begin

        next_pc <= pc_plus_4;
        process (clk, reset)
            begin
                if reset = '1' then
                    current_pc <= x"0000";
                elsif init = '1' then
                    current_pc <= x"0000";
                elsif rising_edge(clk) then 
                    current_pc <= next_pc;
                end if;
            end process;	
end beh;